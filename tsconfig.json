{
  // Typechecks the incrementally-adopted TS code under src (lib, router). The
  // Vue SFCs are still plain JS; switch to vue-tsc as they migrate.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src/**/*.ts"]
}
